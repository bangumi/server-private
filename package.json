{
  "name": "app",
  "version": "0.56.0",
  "description": "",
  "private": true,
  "type": "module",
  "main": "bin/main.ts",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^24.0"
  },
  "scripts": {
    "generate:pb": "rimraf vendor/proto && buf generate upstream/proto",
    "drizzle-pull": "drizzle-kit introspect",
    "format": "prettier --list-different -w ./",
    "tsc": "tsc",
    "lint": "eslint -c eslint.config.mjs ./",
    "build": "node build.mjs",
    "build-common": "node scripts/build-common.mjs",
    "start": "nodemon ./bin/main.ts",
    "start-cron": "nodemon ./bin/cron.ts",
    "start-mq": "nodemon ./bin/mq.ts",
    "test": "vitest --run",
    "vitest": "vitest",
    "file": "node --no-warnings --import tsx/esm",
    "e": "node --no-warnings -r dotenv/config --import tsx/esm",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "codegen": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1024.0",
    "@bgm38/wiki": "0.3.3",
    "@bufbuild/protobuf": "2.11.0",
    "@confluentinc/kafka-javascript": "1.9.0",
    "@fastify/cookie": "11.0.2",
    "@fastify/error": "4.2.0",
    "@fastify/formbody": "8.0.2",
    "@fastify/request-context": "6.2.1",
    "@fastify/sse": "0.4.0",
    "@fastify/static": "9.1.1",
    "@fastify/swagger": "9.7.0",
    "@fastify/type-provider-typebox": "6.1.0",
    "@fastify/view": "11.1.1",
    "@node-rs/bcrypt": "1.10.7",
    "@sentry/node": "10.47.0",
    "@trim21/php-serialize": "0.2.2",
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1",
    "ajv-keywords": "5.1.0",
    "altair-static": "8.5.2",
    "cron": "4.4.0",
    "diff": "8.0.4",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "fastify-metrics": "13.1.0",
    "fastify-socket.io": "5.1.0",
    "got": "15.0.0",
    "graphql": "16.13.2",
    "http-proxy-agent": "9.0.0",
    "http-status-codes": "2.3.0",
    "https-proxy-agent": "9.0.0",
    "ioredis": "5.10.1",
    "js-yaml": "4.1.1",
    "keyv": "5.6.0",
    "liquidjs": "10.25.7",
    "lodash-es": "4.18.1",
    "luxon": "3.7.2",
    "meilisearch": "0.57.0",
    "mercurius": "16.9.0",
    "micromatch": "4.0.8",
    "mime-types": "3.0.2",
    "mysql2": "3.20.0",
    "openapi-types": "12.1.3",
    "parse-duration": "2.1.5",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "socket.io": "4.8.3",
    "socks-proxy-agent": "10.0.0",
    "typebox": "1.1.14",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.67.0",
    "@bufbuild/protoc-gen-es": "2.11.0",
    "@eslint/js": "10.0.1",
    "@graphql-codegen/cli": "6.2.1",
    "@graphql-codegen/introspection": "5.0.1",
    "@graphql-codegen/typescript": "5.0.9",
    "@graphql-codegen/typescript-resolvers": "5.1.7",
    "@shopify/prettier-plugin-liquid": "1.10.2",
    "@types/ioredis-mock": "8.2.7",
    "@types/js-yaml": "4.0.9",
    "@types/lodash-es": "4.17.12",
    "@types/luxon": "3.7.1",
    "@types/mime-types": "3.0.1",
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "@typescript-eslint/utils": "8.58.0",
    "@vitest/coverage-v8": "4.1.2",
    "cheerio": "1.2.0",
    "dotenv": "17.4.0",
    "drizzle-kit": "0.31.10",
    "esbuild": "0.28.0",
    "esbuild-node-externals": "1.21.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-erasable-syntax-only": "0.4.0",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-tsdoc": "0.5.2",
    "eslint-plugin-unicorn": "64.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "graphql-tag": "2.12.6",
    "husky": "9.1.7",
    "ioredis-mock": "8.13.1",
    "lint-staged": "16.4.0",
    "mercurius-integration-testing": "9.0.1",
    "nodemon": "3.1.14",
    "p-limit": "7.3.0",
    "prettier": "3.8.1",
    "prettier-plugin-jsdoc": "1.8.0",
    "rimraf": "6.1.3",
    "std-env": "4.0.0",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.5",
    "vitest": "4.1.2"
  },
  "nodemonConfig": {
    "ignore": [
      "**.test.ts"
    ],
    "watch": [
      "bin",
      "lib",
      "routes",
      "config.yaml",
      "package.json",
      "tsconfig.json",
      ".env"
    ],
    "delay": 100,
    "execMap": {
      "ts": "node --no-warnings -r dotenv/config --import tsx/esm"
    },
    "env": {
      "NODE_ENV": "development",
      "REF": "development"
    },
    "ext": "ts,js,json,html"
  },
  "author": "",
  "prettier": {
    "plugins": [
      "@shopify/prettier-plugin-liquid",
      "prettier-plugin-jsdoc"
    ],
    "tsdoc": true,
    "printWidth": 100,
    "singleQuote": true,
    "semi": true,
    "trailingComma": "all"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@bufbuild/buf",
      "@confluentinc/kafka-javascript",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "fastify-socket.io"
    ],
    "patchedDependencies": {
      "fastify-socket.io": "patches/fastify-socket.io.patch"
    }
  }
}
