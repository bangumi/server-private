        airdate:
          type: string
        comment:
          type: integer
        desc:
          type: string
        disc:
          type: integer
        duration:
          type: string
        id:
          type: integer
        lock:
          type: boolean
        name:
          type: string
        nameCN:
          type: string
        sort:
          type: number
        subjectID:
          type: integer
        type:
