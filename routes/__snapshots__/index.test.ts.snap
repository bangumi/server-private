          in: path
          name: topicID
          required: true
          schema:
            type: integer
      requestBody:
        content:
          application/json:
            examples:
              example1:
                value:
                  cf-turnstile-response: 10000000-aaaa-bbbb-cccc-000000000001
                  content: post contents
              example2:
                value:
                  cf-turnstile-response: 10000000-aaaa-bbbb-cccc-000000000001
                  content: post contents
                  replyTo: 2
            schema:
              properties:
                cf-turnstile-response:
                  minLength: 1
                  type: string
                content:
                  minLength: 1
                  type: string
                replyTo:
                  default: 0
                  description: 被回复的 topic ID, \`0\` 代表回复楼主
                  example: 0
                  type: integer
              required:
                - content
                - cf-turnstile-response
