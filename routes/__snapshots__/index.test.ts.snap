          content:
            application/json:
              examples:
                INVALID_SYNTAX_ERROR:
                  value:
                    code: INVALID_SYNTAX_ERROR
                    error: Bad Request
                    message: '%s'
                    statusCode: 400
              schema:
                $ref: '#/components/schemas/ErrorResponse'
          description: default error response type
        '500':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/ErrorResponse'
                description: 意料之外的服务器错误
          description: 意料之外的服务器错误
      security:
        - CookiesSession: []
      tags:
        - wiki
